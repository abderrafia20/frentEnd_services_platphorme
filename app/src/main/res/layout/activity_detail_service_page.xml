<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">


    <TextView
        android:id="@+id/txtHeaderD"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detail Service"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>


    <TextView
        android:id="@+id/txtTitleD"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Service Title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/txtHeaderD"
        app:layout_constraintStart_toStartOf="parent"/>


    <TextView
        android:id="@+id/txtDescriptionD"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Service Description"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitleD"
        app:layout_constraintStart_toStartOf="parent"/>


    <TextView
        android:id="@+id/txtPriceD"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Price: 0.00"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtDescriptionD"
        app:layout_constraintStart_toStartOf="parent"/>


    <TextView
        android:id="@+id/txtFournisseurD"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Made by: Fournisseur"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtPriceD"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/VcreateSR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:visibility="invisible"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/txtFournisseurD"
        tools:layout_editor_absoluteX="16dp">

        <EditText
            android:id="@+id/edtDescriptionSR"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            android:layout_marginTop="21dp"
            android:background="@drawable/rounded_edittext"
            android:textColorHint="#9B923B"
            android:hint="Description detaile sirvice"
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/errorSR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#FF0000"
            android:textSize="20sp"
            android:textStyle="bold" />


        <Button
            android:id="@+id/btnCreateServiceR"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="52dp"
            android:backgroundTint="#FFD600"
            android:elevation="4dp"
            android:text=" Create Service"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:layout_constraintHorizontal_bias="0.0" />
    </LinearLayout>





</androidx.constraintlayout.widget.ConstraintLayout>