<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Bottom shadow -->
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@android:color/transparent"
                android:endColor="#33000000"
                android:angle="270"/> <!-- shadow ظاهر من الأسفل فقط -->
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- Main white background -->
    <item android:top="0dp" android:left="0dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white"/>
            <corners android:radius="20dp"/>
            <stroke
                android:width="1dp"
                android:color="#FFD600"/>
        </shape>
    </item>

</layer-list>